# ── App ───────────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=gatherhub
DB_PASSWORD=gatherhub
DB_NAME=gatherhub
DB_SSLMODE=disable

# ── Storage ───────────────────────────────────────────────────
# Absolute path to the runtime storage directory.
# MUST be outside the Git repository to prevent uploads from being committed.
#
# Local development (default — sibling directory of the repo):
STORAGE_PATH=../gatherhub-storage
#
# Docker (override in docker-compose.yml via environment:):
# STORAGE_PATH=/storage
#
# Sub-directories created automatically on startup:
#   {STORAGE_PATH}/payments/   — payment proof uploads
#   {STORAGE_PATH}/events/     — event banner uploads
#   {STORAGE_PATH}/temp/       — temporary files

# ── Frontend (served by Fiber for local dev) ──────────────────
FRONTEND_DIR=../frontend

# ── Admin ─────────────────────────────────────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_EMAIL=admin@gatherhub.local
SESSION_SECRET=gatherhub-secret-change-in-production
